{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Live security dashboard — alerts and event counts from PostgreSQL",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Total number of alerts in the selected time range",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "title": "Total Alerts",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS total_alerts FROM alerts WHERE created_at BETWEEN $__timeFrom() AND $__timeTo()",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Number of critical severity alerts in the selected time range",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "title": "Critical Alerts",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS critical FROM alerts WHERE severity = 'critical' AND created_at BETWEEN $__timeFrom() AND $__timeTo()",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Total event count across all actions in the selected time range",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "title": "Total Events",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(count) AS total_events FROM event_counts WHERE window_start BETWEEN $__timeFrom() AND $__timeTo()",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Number of unique IPs that triggered alerts",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "title": "Unique IPs",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT ip) AS unique_ips FROM alerts WHERE created_at BETWEEN $__timeFrom() AND $__timeTo()",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Alert count over time grouped by severity",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.4.0",
      "title": "Alerts Over Time (by Severity)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT window_start AS time, severity, COUNT(*) AS alert_count FROM alerts WHERE $__timeFilter(window_start) GROUP BY window_start, severity ORDER BY window_start",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Breakdown of alerts by severity level",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 4 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "pieType": "pie",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "10.4.0",
      "title": "Alerts by Severity",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT severity, COUNT(*) AS count FROM alerts WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() GROUP BY severity ORDER BY count DESC",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Event counts per action type over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 4,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 12 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.4.0",
      "title": "Event Counts Over Time (by Action)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT window_start AS time, action, SUM(count) AS event_count FROM event_counts WHERE $__timeFilter(window_start) GROUP BY window_start, action ORDER BY window_start",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Total event volume split by action type",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 12 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "10.4.0",
      "title": "Event Volume by Action",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT action, SUM(count) AS total FROM event_counts WHERE window_start BETWEEN $__timeFrom() AND $__timeTo() GROUP BY action ORDER BY total DESC",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Top offending IPs ranked by total alert count",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "count" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "gauge" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 20 }] } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 9,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "count" }]
      },
      "pluginVersion": "10.4.0",
      "title": "Top IPs by Alert Count",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ip, rule, COUNT(*) AS count, MAX(severity) AS max_severity FROM alerts WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() GROUP BY ip, rule ORDER BY count DESC LIMIT 20",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
      "description": "Most recently triggered alerts",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "color": "red",    "index": 0 } } },
                  { "type": "value", "options": { "high":     { "color": "orange", "index": 1 } } },
                  { "type": "value", "options": { "medium":   { "color": "yellow", "index": 2 } } },
                  { "type": "value", "options": { "low":      { "color": "green",  "index": 3 } } }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "created_at" }]
      },
      "pluginVersion": "10.4.0",
      "title": "Recent Alerts",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "DS_POSTGRESQL" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT created_at, ip, rule, severity, count FROM alerts WHERE created_at BETWEEN $__timeFrom() AND $__timeTo() ORDER BY created_at DESC LIMIT 50",
          "refId": "A"
        }
      ]
    }

  ],
