  "schemaVersion": 39,
  "tags": ["security", "alerts", "events", "postgres"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Security Dashboard",
  "uid": "security-dashboard",
  "version": 1
}